#!/usr/bin/env ruby
# Instiki server entry point. Boots Rails via config.ru and runs the app
# under Thin (preferred) or WEBrick. Recognises Instiki's historical CLI
# flags including -P/--path for mounting under a URL prefix; everything
# else (-p, -b, -c, -d, -e) maps onto rackup options.
#
# This file is a thin shim around Rack/Rackup. It exists rather than
# delegating to `bin/rails server` because Instiki defaults the port to
# 2500 and supports the -P prefix mount, neither of which Rails' built-in
# server command provides.

require "fileutils"
require "optparse"

options = {
  Port: 2500,
  Host: "0.0.0.0",
  environment: ENV["RAILS_ENV"] || "production",
  config: File.expand_path("../config.ru", __dir__),
  daemonize: false,
  path: nil,
}

OptionParser.new do |opts|
  opts.banner = "Usage: instiki [options]"
  opts.on("-p", "--port=PORT",        Integer, "Port (default: 2500)")              { |v| options[:Port] = v }
  opts.on("-b", "--binding=IP",       String,  "Host to bind to (default: 0.0.0.0)") { |v| options[:Host] = v }
  opts.on("-c", "--config=FILE",      String,  "Rackup config (default: config.ru)") { |v| options[:config] = v }
  opts.on("-d", "--daemon",                    "Run as a background daemon")        { options[:daemonize] = true }
  opts.on("-e", "--environment=ENV",  String,  "Rails environment (default: production)") { |v| options[:environment] = v }
  opts.on("-P", "--path=/prefix",     String,  "Mount Instiki under a URL prefix")  { |v| options[:path] = v }
  opts.on_tail("-h", "--help",                 "Show this help message")            { puts opts; exit }
end.parse!(ARGV)

# Set env before Rails boots so initialization sees the right values.
ENV["RAILS_ENV"] = options[:environment]
ENV["RAILS_RELATIVE_URL_ROOT"] = options[:path] if options[:path]

# Bundler setup, then Rack/Rackup, then load the app from config.ru
# (which requires config/environment internally and boots Rails).
require_relative "../config/boot"
require "rack"
require "rackup"

app = Rack::Builder.parse_file(options[:config])

# Mount under -P prefix using Rack::Builder#map.
if options[:path]
  inner  = app
  prefix = options[:path]
  app = Rack::Builder.new do
    map(prefix) { run inner }
  end.to_app
end

# Pick a handler. Thin 2.x ships its handler at Thin::Rackup::Handler
# rather than where Rackup::Handler.get("thin") looks (Thin's legacy
# rack/handler/thin.rb still requires Rack 2's rack/handler, which Rack 3
# has moved). Resolve it directly; fall back to WEBrick.
handler =
  begin
    require "thin"
    require "thin/rackup/handler"
    Thin::Rackup::Handler
  rescue LoadError
    require "rackup/handler/webrick"
    Rackup::Handler::WEBrick
  end

# Pre-create dirs Instiki writes into.
%w[cache pids sessions sockets].each do |d|
  FileUtils.mkdir_p(Rails.root.join("tmp", d))
end

if options[:daemonize]
  pid_file = Rails.root.join("tmp", "pids", "server.pid")
  Process.daemon
  File.write(pid_file, Process.pid)
  at_exit { File.delete(pid_file) if File.exist?(pid_file) }
end

trap(:INT)  { exit }
trap(:TERM) { exit }

handler_name = handler.name.split("::").last
puts "=> Booting #{handler_name}"
puts "=> Rails #{Rails.version} application starting on http://#{options[:Host]}:#{options[:Port]}#{options[:path]}"
puts "=> Call with -d to detach" unless options[:daemonize]
puts "=> Ctrl-C to shutdown server"

handler.run(app, Host: options[:Host], Port: options[:Port])
